{
  "version": "0.1.1",
  "name": "mongoose-zod",
  "description": "Create Mongoose schemas using Zod.",
  "scripts": {
    "lint:eslint": "eslint **/*.{js,ts}",
    "lint:eslint:fix": "eslint **/*.{js,ts} --fix",
    "lint:editorconfig": "editorconfig-checker",
    "lint:types": "tsc --noEmit",
    "lint": "npm run lint:editorconfig && npm run lint:types && npm run lint:eslint",
    "test:unit": "bun test",
    "test:unit:watch": "bun test --watch",
    "test": "npm run lint && npm run test:unit",
    "build": "rimraf dist && tsup src/index.ts --dts --treeshake --format esm,cjs --target=node24",
    "prepublishOnly": "npm run test && npm run build"
  },
  "homepage": "https://github.com/andreww2012/mongoose-zod",
  "repository": {
    "type": "git",
    "url": "https://github.com/andreww2012/mongoose-zod"
  },
  "bugs": {
    "url": "https://github.com/andreww2012/mongoose-zod/issues/new"
  },
  "keywords": [
    "mongoose",
    "zod",
    "mongodb"
  ],
  "author": "harm@nullix.nl",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "trailingComma": "all",
    "bracketSpacing": false,
    "endOfLine": "lf"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.3",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.10",
    "@types/lodash": "4.17.23",
    "@types/node": "24.12.0",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "bun": "1.3.11",
    "editorconfig-checker": "6.1.1",
    "eslint": "10.1.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-alias": "1.1.2",
    "eslint-import-resolver-typescript": "1.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.1",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-optimize-regex": "1.2.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-require-extensions": "0.1.3",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.4.0",
    "jest": "30.3.0",
    "lodash": "4.17.23",
    "mongodb-memory-server": "11.0.1",
    "mongoose": "8.23.0",
    "mongoose-lean-defaults": "2.3.1",
    "mongoose-lean-getters": "2.3.1",
    "mongoose-lean-virtuals": "2.1.0",
    "mongoose-long": "0.8.0",
    "prettier": "3.8.1",
    "release-it": "19.2.4",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.6",
    "ts-jest-mock-import-meta": "1.3.1",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "zod": "^3.19.1"
  },
  "peerDependencies": {
    "mongoose": "^8.x",
    "mongoose-lean-defaults": "^2.x",
    "mongoose-lean-getters": "^2.x",
    "mongoose-lean-virtuals": "^2.x",
    "zod": "^3.x"
  },
  "peerDependenciesMeta": {
    "mongoose-lean-defaults": {
      "optional": true
    },
    "mongoose-lean-getters": {
      "optional": true
    },
    "mongoose-lean-virtuals": {
      "optional": true
    }
  }
}
